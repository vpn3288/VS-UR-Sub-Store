# Upstash Redis REST API 配置
# 从 Upstash 控制台获取: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# 缓存配置
CACHE_TTL=300                    # 缓存过期时间（秒），默认 300（5分钟）
CACHE_MAX_SIZE=100               # 最大缓存条目数，默认 100
MEMORY_CACHE_ENABLED=true        # 是否启用内存缓存，默认 true

# 速率限制
RATE_LIMIT_MAX=100               # 每分钟最大请求数，默认 100

# API 安全
API_SECRET=your_secret_key       # API 签名密钥（可选）

# Node 环境
NODE_ENV=production
